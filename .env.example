APP_NAME=HRMS Backend API
APP_VERSION=1.0.0
DEBUG=true
PORT=8000

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hrms

JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

OFFICE_START_HOUR=10
OFFICE_START_MINUTE=0
LATE_AFTER_HOUR=10
LATE_AFTER_MINUTE=15
FULL_DAY_HOURS=8
HALF_DAY_MIN_HOURS=4
OVERTIME_MAX_HOURS_PER_DAY=6

LATE_DEDUCTION_PER_MARK=250
LEAVE_DEDUCTION_PER_DAY=500
OVERTIME_HOURLY_RATE_MULTIPLIER=1.5
